# ============================================================
# Jenkins
# Replace the hash below with:
#   docker run --rm -it caddy:2.8-alpine caddy hash-password --plaintext "YOUR_PASSWORD"
# ============================================================
jenkins.plantprocessiq.com {
    encode zstd gzip

    basicauth {
        admin $2a$14$REPLACE_WITH_REAL_CADDY_BCRYPT_HASH
    }

    reverse_proxy jenkins:8080

    header {
        -Server
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Referrer-Policy no-referrer
    }
}