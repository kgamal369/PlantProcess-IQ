# ============================================================
# PlantProcess IQ - Unified Demo / GTM Deployment Environment
# Copy to .env and fill real values. Never commit .env.
# ============================================================

# ------------------------------------------------------------
# Deployment identity
# ------------------------------------------------------------
COMPOSE_PROJECT_NAME=plantprocessiq
DEPLOYMENT_ENVIRONMENT=Demo

# ------------------------------------------------------------
# Domains
# Replace later with real domain:
# plantprocessiq.com
# app.plantprocessiq.com
# api.plantprocessiq.com
# jenkins.plantprocessiq.com
# ------------------------------------------------------------
PUBLIC_WEBSITE_HOST=website.localhost
APP_FRONTEND_HOST=app.localhost
APP_API_HOST=api.localhost
WEBSITE_API_HOST=website-api.localhost
JENKINS_HOST=jenkins.localhost

# ------------------------------------------------------------
# PostgreSQL
# One PostgreSQL instance, two databases:
# 1. plantprocess_app_db
# 2. plantprocess_website_db
# ------------------------------------------------------------
POSTGRES_USER=plantprocess_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
POSTGRES_APP_DB=plantprocess_app_db
POSTGRES_WEBSITE_DB=plantprocess_website_db
POSTGRES_PORT=5432

# App DB connection used by API and Workers
ConnectionStrings__PlantProcessDb=Host=postgres;Port=5432;Database=plantprocess_app_db;Username=plantprocess_admin;Password=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# Website DB connection used by website backend
ConnectionStrings__WebsiteDb=Host=postgres;Port=5432;Database=plantprocess_website_db;Username=plantprocess_admin;Password=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ------------------------------------------------------------
# App backend
# ------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5063

PlantProcess__Auth__Issuer=PlantProcessIQ
PlantProcess__Auth__Audience=PlantProcessIQ.Client
PlantProcess__Auth__SigningKey=CHANGE_ME_64_CHAR_RANDOM_SIGNING_KEY_FOR_DEMO_ENVIRONMENT
PlantProcess__Auth__BootstrapAdminUser=admin
PlantProcess__Auth__BootstrapAdminPassword=CHANGE_ME_STRONG_ADMIN_PASSWORD

PlantProcess__PlantTimeZoneId=Europe/Berlin
PlantProcess__PlantUtcOffsetMinutes=60

PLANTPROCESS_ALLOWED_ORIGINS=https://app.localhost,http://app.localhost,http://localhost:5173

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
VITE_API_BASE_URL=https://api.localhost

# ------------------------------------------------------------
# Jenkins
# ------------------------------------------------------------
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=CHANGE_ME_STRONG_JENKINS_PASSWORD

# ------------------------------------------------------------
# Storage paths inside host machine
# ------------------------------------------------------------
HOST_DATA_ROOT=/data/plantprocess-iq
HOST_POSTGRES_DATA=/data/plantprocess-iq/postgres
HOST_APP_DUMPS=/data/plantprocess-iq/app-dumps
HOST_LOGS=/data/plantprocess-iq/logs
HOST_REPORTS=/data/plantprocess-iq/reports
HOST_BACKUPS=/data/plantprocess-iq/backups
HOST_JENKINS_HOME=/data/plantprocess-iq/jenkins