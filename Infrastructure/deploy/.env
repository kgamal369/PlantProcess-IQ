# ============================================================
# PlantProcess IQ - Unified Demo / GTM Deployment Environment
# LOCAL DEMO ONLY - Do not commit this file.
# ============================================================

# ------------------------------------------------------------
# Deployment identity
# ------------------------------------------------------------
COMPOSE_PROJECT_NAME=plantprocessiq
DEPLOYMENT_ENVIRONMENT=Demo

# ------------------------------------------------------------
# Domains
# Replace later with real domain:
# plantprocessiq.com
# app.plantprocessiq.com
# api.plantprocessiq.com
# jenkins.plantprocessiq.com
# ------------------------------------------------------------
PUBLIC_WEBSITE_HOST=website.localhost
APP_FRONTEND_HOST=app.localhost
APP_API_HOST=api.localhost
WEBSITE_API_HOST=website-api.localhost
JENKINS_HOST=jenkins.localhost

# ------------------------------------------------------------
# PostgreSQL
# One PostgreSQL instance, two databases:
# 1. plantprocess_app_db
# 2. plantprocess_website_db
#
# Note:
# Website DB is reserved for later. Current website is static.
# ------------------------------------------------------------
POSTGRES_USER=plantprocess_admin
POSTGRES_PASSWORD=THEspider369
POSTGRES_APP_DB=plantprocess_app_db
POSTGRES_WEBSITE_DB=plantprocess_website_db
POSTGRES_PORT=5432

# App DB connection used by API and Workers
ConnectionStrings__PlantProcessDb=Host=postgres;Port=5432;Database=plantprocess_app_db;Username=plantprocess_admin;Password=THEspider369

# Website DB connection reserved for future website backend
ConnectionStrings__WebsiteDb=Host=postgres;Port=5432;Database=plantprocess_website_db;Username=plantprocess_admin;Password=THEspider369

# ------------------------------------------------------------
# App backend
# ------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
DOTNET_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5063

PlantProcess__Auth__Issuer=PlantProcessIQ
PlantProcess__Auth__Audience=PlantProcessIQ.Client

# Must be at least 32 characters. Local demo only.
PlantProcess__Auth__SigningKey=THEspider369THEspider369THEspider369THEspider369

PlantProcess__Auth__BootstrapAdminUser=admin
PlantProcess__Auth__BootstrapAdminPassword=THEspider369

PlantProcess__PlantTimeZoneId=Europe/Berlin
PlantProcess__PlantUtcOffsetMinutes=60

PLANTPROCESS_ALLOWED_ORIGINS=https://app.localhost,http://app.localhost,http://localhost:5173

# ------------------------------------------------------------
# Frontend
# ------------------------------------------------------------
VITE_API_BASE_URL=http://api.localhost

# ------------------------------------------------------------
# Jenkins
# ------------------------------------------------------------
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=THEspider369

# ------------------------------------------------------------
# Storage paths inside host machine
# Windows local demo paths.
# Later on Linux VPS, change back to /data/plantprocess-iq/...
# ------------------------------------------------------------
HOST_DATA_ROOT=C:/Workspace/PlantProcess-IQ/.runtime/plantprocess-iq
HOST_POSTGRES_DATA=C:/Workspace/PlantProcess-IQ/.runtime/plantprocess-iq/postgres
HOST_APP_DUMPS=C:/Workspace/PlantProcess-IQ/.runtime/plantprocess-iq/app-dumps
HOST_LOGS=C:/Workspace/PlantProcess-IQ/.runtime/plantprocess-iq/logs
HOST_REPORTS=C:/Workspace/PlantProcess-IQ/.runtime/plantprocess-iq/reports
HOST_BACKUPS=C:/Workspace/PlantProcess-IQ/.runtime/plantprocess-iq/backups
HOST_JENKINS_HOME=C:/Workspace/PlantProcess-IQ/.runtime/plantprocess-iq/jenkins