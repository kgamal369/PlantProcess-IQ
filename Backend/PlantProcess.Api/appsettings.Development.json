{
  "ConnectionStrings": {
    "PlantProcessDb": ""
  },
  "PlantProcess": {
    "RequireDatabaseConnectionString": true,
    "PlantTimeZoneId": "Europe/Berlin",
    "PlantUtcOffsetMinutes": 60,
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ],
    "Auth": {
      "Issuer": "PlantProcessIQ",
      "Audience": "PlantProcessIQ.Client",
      "SigningKey": "dev-local-signing-key-please-change-0123456789ABCDEF",
      "AccessTokenMinutes": 120,
      "BootstrapAdminUser": "admin",
      "BootstrapAdminPassword": "Admin123!",
      "Users": [
        {
          "UserName": "admin",
          "Password": "Admin123!",
          "Role": "Admin",
          "DisplayName": "Development Admin"
        },
        {
          "UserName": "engineer",
          "Password": "Engineer123!",
          "Role": "Engineer",
          "DisplayName": "Development Engineer"
        },
        {
          "UserName": "datamanager",
          "Password": "DataManager123!",
          "Role": "DataManager",
          "DisplayName": "Development Data Manager"
        },
        {
          "UserName": "viewer",
          "Password": "Viewer123!",
          "Role": "Viewer",
          "DisplayName": "Development Viewer"
        }
      ]
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  }
}