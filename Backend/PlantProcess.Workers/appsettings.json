{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "ConnectionStrings": {
    "PlantProcessDb": ""
  },

  "PlantProcess": {
    "Workers": {
      "EnableImportQueueProcessorJob":     true,
      "ImportQueueProcessorIntervalSeconds": 120,
      "ImportQueueProcessorMaxBatches":    5,
      "ImportQueueProcessorRowsPerBatch":  5000,

      "EnableDataQualityScanJob":          true,
      "DataQualityScanIntervalSeconds":    3600,
      "DataQualityMaxCandidatesPerRule":   500,

      "EnableRiskScoringJob":              true,
      "RiskScoringIntervalSeconds":        7200,
      "RiskScoringMaxMaterials":           100,
      "RiskScoringRiskType":               "OverallQualityRisk"
    }
  }
}