# PostgreSQL product database
POSTGRES_HOST=plantprocess-db
POSTGRES_PORT=5432
POSTGRES_DB=plantprocessiq
POSTGRES_USER=plantprocess
POSTGRES_PASSWORD=SET_LOCAL_POSTGRES_PASSWORD

# Host ports
PLANTPROCESS_API_PORT=5063
PLANTPROCESS_WEB_PORT=5173
PLANTPROCESS_DB_HOST_PORT=5432

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5063

# Connection string consumed by API and Workers
ConnectionStrings__PlantProcessDb=Host=plantprocess-db;Port=5432;Database=plantprocessiq;Username=plantprocess;Password=SET_LOCAL_POSTGRES_PASSWORD

# CORS
PLANTPROCESS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Vite frontend
VITE_HOST=0.0.0.0
VITE_PORT=5173
VITE_PREVIEW_PORT=4173
VITE_API_BASE_URL=http://localhost:5063

# ------------------------------------------------------------
# PlantProcess IQ License / Commercial Feature Gates
# Light | Pro | ProPlus | Enterprise
# ------------------------------------------------------------
PlantProcess__License__Tier=ProPlus
PlantProcess__License__IsTrial=false
PlantProcess__License__DisplayName=Pro Plus Demo License