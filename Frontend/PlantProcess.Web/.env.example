# =============================================================================
# PlantProcess IQ - Full Stack Environment Template
# =============================================================================

# -----------------------------------------------------------------------------
# Ports
# -----------------------------------------------------------------------------
API_PORT=5063
WEB_PORT=5173
DB_PORT=5432

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=plantprocessiq
POSTGRES_USER=plantprocess
POSTGRES_PASSWORD=plantprocess123

# -----------------------------------------------------------------------------
# Backend / ASP.NET Core
# -----------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Used by Docker/container mode.
ConnectionStrings__PlantProcessDb=Host=db;Port=5432;Database=plantprocessiq;Username=plantprocess;Password=plantprocess123

# Used by Program.cs custom fallback parser.
PLANTPROCESS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional strongly-typed .NET config style.
PlantProcess__PlantTimeZoneId=Europe/Berlin
PlantProcess__PlantUtcOffsetMinutes=60
PlantProcess__AllowedOrigins__0=http://localhost:5173
PlantProcess__AllowedOrigins__1=http://localhost:3000
PlantProcess__RequireConfiguredCors=true
PlantProcess__RequireDatabaseConnectionString=true

# -----------------------------------------------------------------------------
# Frontend / Vite
# -----------------------------------------------------------------------------
VITE_HOST=0.0.0.0
VITE_PORT=5173
VITE_PREVIEW_PORT=4173
VITE_API_BASE_URL=http://localhost:5063

# -----------------------------------------------------------------------------
# Smoke tests
# -----------------------------------------------------------------------------
PLANTPROCESS_SMOKE_API_BASE_URL=http://localhost:5063
PLANTPROCESS_SMOKE_WEB_BASE_URL=http://localhost:5173