# ===========================================================
# TASK 15 — Create full-stack .env.example
# FILE: .env.example  (repository root)
#
# HOW TO USE:
#   1. Copy this file to .env  (never commit .env)
#      cp .env.example .env
#   2. Fill in the values marked <CHANGE_ME>
#   3. For local dev, you can also use:
#       Backend/PlantProcess.Api/appsettings.Development.json
#       (via dotnet user-secrets — see that file for instructions)
#
# This file covers:
#   - Backend API (PlantProcess.Api)
#   - Workers     (PlantProcess.Workers)
#   - Frontend    (PlantProcess.Web via Vite)
#   - Docker Compose (docker-compose.yml)
# ===========================================================


# ── PostgreSQL ───────────────────────────────────────────────
# Used by Docker Compose to create the database on first run.
POSTGRES_DB=plantprocessiq
POSTGRES_USER=plantprocess
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_PORT=5432

# Full connection string consumed by the API and Workers.
# Format: Host=<host>;Port=<port>;Database=<db>;Username=<user>;Password=<password>
# In Docker Compose this will typically be:
#   Host=postgres;Port=5432;Database=plantprocessiq;Username=plantprocess;Password=<same as POSTGRES_PASSWORD>
ConnectionStrings__PlantProcessDb=Host=localhost;Port=5432;Database=plantprocessiq;Username=plantprocess;Password=<CHANGE_ME>


# ── Backend API port ─────────────────────────────────────────
# Overrides applicationUrl in launchSettings.json.
# Format: http://0.0.0.0:<port>  (0.0.0.0 required inside Docker)
ASPNETCORE_URLS=http://0.0.0.0:5063


# ── CORS — allowed frontend origins ─────────────────────────
# Comma-separated list of origins allowed to call the API.
# For local dev:    http://localhost:5173,http://localhost:3000
# For Docker demo:  http://localhost:5173
# For production:   https://plantprocess.yourdomain.com
PLANTPROCESS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Plant time zone ──────────────────────────────────────────
# IANA time zone ID of the plant.
# Common: Europe/Berlin, UTC, America/New_York, Asia/Shanghai
PlantProcess__PlantTimeZoneId=Europe/Berlin
PlantProcess__PlantUtcOffsetMinutes=60


# ── ASP.NET Core environment ─────────────────────────────────
# Values: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development


# ── Frontend — Vite ──────────────────────────────────────────
# Required: full URL of the backend API.  No trailing slash.
VITE_API_BASE_URL=http://localhost:5063

# Optional: change the Vite dev server port (default 5173).
VITE_PORT=5173

# Optional: change the Vite preview port (default 4173).
VITE_PREVIEW_PORT=4173

# Optional: bind address for Vite dev server.
VITE_HOST=0.0.0.0


# ── Docker Compose port mappings ─────────────────────────────
# These control which host ports are mapped to container ports.
# Change only if the defaults conflict with existing services.
API_HOST_PORT=5063
WEB_HOST_PORT=5173
POSTGRES_HOST_PORT=5432


# ── Worker job settings ──────────────────────────────────────
# All three jobs are enabled by default.
PlantProcess__Workers__EnableImportQueueProcessorJob=true
PlantProcess__Workers__ImportQueueProcessorIntervalSeconds=120
PlantProcess__Workers__ImportQueueProcessorMaxBatches=5

PlantProcess__Workers__EnableDataQualityScanJob=true
PlantProcess__Workers__DataQualityScanIntervalSeconds=3600

PlantProcess__Workers__EnableRiskScoringJob=true
PlantProcess__Workers__RiskScoringIntervalSeconds=7200
PlantProcess__Workers__RiskScoringMaxMaterials=100


# ── Future: secret vault integration ─────────────────────────
# Reserved for Task 29 (SecretReference) and Task 83.
# PLANTPROCESS_SECRET_PROVIDER=env          # env | docker | keyvault
# AZURE_KEYVAULT_URI=https://your-vault.vault.azure.net/
