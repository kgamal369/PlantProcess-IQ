{
  "name": "plantprocess-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "check:ts": "tsc -b --verbose",
    "size-check": "node scripts/check-bundle-size.mjs",
    "contract:api": "vitest run src/api/legacy/__tests__/plantProcessApi.contract.test.ts --config vitest.config.ts",
    "language:audit": "node scripts/audit-language.mjs",
    "qa:hardening": "playwright test e2e/hardening-matrix.spec.ts e2e/widget-builder-focused.spec.ts e2e/admin-db-focused.spec.ts e2e/admin-schema-focused.spec.ts",
    "qa:nav": "playwright test e2e/nav-graph-refresh-survival.spec.ts",
    "qa:license": "playwright test e2e/license-gate-ux.spec.ts",
    "qa:dashboard": "playwright test e2e/dashboard-refresh-filter.spec.ts",
    "qa:phase1": "playwright test e2e/phase1-golden-demo.spec.ts e2e/phase1-button-action-matrix.spec.ts",
    "qa:phase1:hardening": "playwright test e2e/phase1-route-refresh.spec.ts e2e/phase1-button-action-matrix.spec.ts e2e/phase1-toast-mapping.spec.ts",
    "validate": "npm run build && npm run lint && npm run test",
    "validate:phase1": "npm run build && npm run test && npm run qa:phase1",
    "validate:phase1:hardening": "npm run build && npm run qa:phase1:hardening",
    "validate:fast": "npm run build && npm run test",
    "validate:full": "npm run build && npm run lint && npm run test && npm run language:audit && npm run e2e",
    "validate:api-policy": "node scripts/validate-api-client-policy.mjs",
    "validate:no-console": "node scripts/validate-no-console-in-src.mjs",
    "validate:ui-system": "node scripts/validate-ui-system-rollout.mjs",
    "qa:phase2:step1": "playwright test -c playwright.phase2.config.ts e2e/phase2-zero-console-production.spec.ts e2e/phase2-backend-outage.spec.ts e2e/phase2-navigation-refresh-survival.spec.ts",
    "qa:phase2:step2": "playwright test -c playwright.phase2.config.ts e2e/phase2-chart-interaction.spec.ts e2e/phase2-responsive-multibrowser.spec.ts",
    "validate:phase2:step1-step2": "npm run build && npm run validate:api-policy && npm run validate:no-console && npm run validate:ui-system && npm run qa:phase2:step1 && npm run qa:phase2:step2",
    "validate:copy": "node scripts/validate-forbidden-copy.mjs",
    "qa:phase1:security": "playwright test e2e/phase1-security-hardening.spec.ts --project=chromium",
    "build:storybook": "storybook build",
    "validate:phase2:ui-standards": "npm run ui:audit && npm run ui:validate && npm run build",
    "storybook": "storybook dev -p 6006",
    "ui:validate": "node tools/ui/validate-ui-standards.mjs",
    "ui:audit": "node tools/ui/audit-ui-instances.mjs",
    "ui:inventory": "node tools/ui/generate-ui-standards-inventory.mjs",
    "ui:validate:phase2-full": "node tools/ui/validate-phase2-full-ui-standards.mjs",
    "test:ui-standards": "vitest run src/components/standard/__tests__ --config vitest.config.ts",
    "validate:phase2:ui-standards-full": "npm run ui:inventory && npm run ui:validate:phase2-full && npm run test:ui-standards && npm run build && npm run build:storybook",
    "validate:phase3-phase4:material": "npm run build && npm run lint",
    "phase34:acceptance": "node tools/phase3/validate-phase3-phase4-acceptance.cjs",
    "validate:phase3-phase4:strict": "npm run build && npm run lint && npm run phase34:acceptance"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^3.2.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^28.1.0",
    "msw": "^2.14.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "storybook": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/addon-a11y": "^10.0.0"
  }
}
